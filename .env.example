APP_NAME=Velra
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://velra:velra@postgres:5432/velra
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=900

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

USE_CHROMA_HTTP=true
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_NAME=chat_analyses
CHROMA_PERSIST_DIRECTORY=./.chroma

UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="token..."
